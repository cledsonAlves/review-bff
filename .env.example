# Application settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# HuggingFace cache — redireciona download dos modelos para dentro do projeto
# Evita problemas de permissão no diretório global ~/.cache/huggingface
HF_HOME=./.hf_cache

# Scraping defaults
DEFAULT_LANG=pt
DEFAULT_COUNTRY=br
DEFAULT_REVIEW_COUNT=100
MAX_REVIEW_COUNT=500
